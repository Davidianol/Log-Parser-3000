    {
      "name": "Topology",
      "item": [
        {
          "name": "GET /api/topology/{log_id} — успешно",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Ответ содержит nodes и groups (snake_case)', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('nodes');",
                  "    pm.expect(json).to.have.property('groups');",
                  "    pm.expect(json.nodes).to.be.an('array');",
                  "    pm.expect(json.groups).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('nodes содержит 5 узлов (1 host + 4 switch)', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.nodes.length).to.eql(5);",
                  "});",
                  "",
                  "pm.test('Присутствуют оба типа узлов: host (1) и switch (2)', function() {",
                  "    var json = pm.response.json();",
                  "    var types = json.nodes.map(function(n) { return n.node_type; });",
                  "    pm.expect(types).to.include(1);",
                  "    pm.expect(types).to.include(2);",
                  "});",
                  "",
                  "pm.test('groups содержит host_active и switch_active', function() {",
                  "    var json = pm.response.json();",
                  "    var keys = json.groups.map(function(g) { return g.key; });",
                  "    pm.expect(keys).to.include('host_active');",
                  "    pm.expect(keys).to.include('switch_active');",
                  "});",
                  "",
                  "pm.test('Каждая группа содержит key и node_guids (snake_case)', function() {",
                  "    var json = pm.response.json();",
                  "    json.groups.forEach(function(g) {",
                  "        pm.expect(g).to.have.property('key');",
                  "        pm.expect(g).to.have.property('node_guids');",
                  "        pm.expect(g.node_guids).to.be.an('array');",
                  "    });",
                  "});",
                  "",
                  "pm.test('switch_active содержит 4 узла', function() {",
                  "    var json = pm.response.json();",
                  "    var sw = json.groups.find(function(g) { return g.key === 'switch_active'; });",
                  "    pm.expect(sw).to.exist;",
                  "    pm.expect(sw.node_guids.length).to.eql(4);",
                  "});",
                  "",
                  "pm.test('Все node_guid начинаются с 0x', function() {",
                  "    var json = pm.response.json();",
                  "    json.nodes.forEach(function(n) {",
                  "        pm.expect(n.node_guid).to.match(/^0x/);",
                  "    });",
                  "});",
                  "",
                  "// Сохраняем node_id первого узла (HOST_1, id=1)",
                  "var json = pm.response.json();",
                  "if (json && json.nodes && json.nodes.length > 0) {",
                  "    pm.collectionVariables.set('node_id', json.nodes[0].id);",
                  "    console.log('node_id сохранён:', json.nodes[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/topology/{{log_id}}",
