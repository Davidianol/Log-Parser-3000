    {
      "name": "Log",
      "item": [
        {
          "name": "GET /api/log/{log_id} — успешно",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Лог содержит обязательные поля', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json).to.have.property('filename');",
                  "    pm.expect(json).to.have.property('status');",
                  "    pm.expect(json).to.have.property('node_count');",
                  "    pm.expect(json).to.have.property('uploaded_at');",
                  "});",
                  "",
                  "pm.test('Статус лога — done', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('done');",
                  "});",
                  "",
                  "pm.test('node_count равен 5 (из лога: 1 host + 4 switch)', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.node_count).to.eql(5);",
                  "});",
                  "",
                  "pm.test('filename — log.zip', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.filename).to.eql('log.zip');",
                  "});",
                  "",
                  "pm.test('error_message равен null', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.error_message).to.be.null;",
                  "});"
                ],
