                  "});",
                  "",
                  "pm.test('Каждый порт содержит обязательные поля (snake_case)', function() {",
                  "    var json = pm.response.json();",
                  "    json.forEach(function(port) {",
                  "        pm.expect(port).to.have.property('id');",
                  "        pm.expect(port).to.have.property('node_id');",
                  "        pm.expect(port).to.have.property('node_guid');",
                  "        pm.expect(port).to.have.property('port_guid');",
                  "        pm.expect(port).to.have.property('port_num');",
                  "        pm.expect(port).to.have.property('port_state');",
                  "        pm.expect(port).to.have.property('lid');",
                  "        pm.expect(port).to.have.property('cap_msk');",
                  "    });",
                  "});",
                  "",
                  "pm.test('port_state в допустимом диапазоне [0-4]', function() {",
                  "    var json = pm.response.json();",
                  "    json.forEach(function(port) {",
                  "        pm.expect(port.port_state).to.be.within(0, 4);",
                  "    });",
                  "});",
                  "",
                  "pm.test('cap_msk является числом', function() {",
                  "    var json = pm.response.json();",
                  "    json.forEach(function(port) {",
                  "        pm.expect(port.cap_msk).to.be.a('number');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Строковые поля (link_round_trip_latency, ooo_sl_mask) присутствуют если не N/A', function() {",
                  "    var json = pm.response.json();",
                  "    json.forEach(function(port) {",
                  "        if (port.hasOwnProperty('link_round_trip_latency')) {",
                  "            pm.expect(port.link_round_trip_latency).to.be.a('string');",
                  "        }",
                  "    });",
