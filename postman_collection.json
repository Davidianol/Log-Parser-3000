      "item": [
        {
          "name": "POST /api/parse/ — успешный парсинг",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Ответ содержит log_id', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('log_id');",
                  "    pm.expect(json.log_id).to.be.a('number');",
                  "    pm.expect(json.log_id).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Content-Type is JSON', function() {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (json && json.log_id) {",
                  "    pm.collectionVariables.set('log_id', json.log_id);",
                  "    console.log('log_id сохранён:', json.log_id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
